{
	"tabWidth": 4,
	"useTabs": true,
	"printWidth": 180,
	"singleQuote": true,
	"jsxSingleQuote": true,
	"trailingComma": "es5",
	"tailwindStylesheet": "./src/index.css",
	"plugins": ["prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": "**/*.{yml,yaml}",
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		}
	]
}
